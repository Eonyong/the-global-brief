# ── The Global Brief — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit your actual .env file to Git!

# Required: Anthropic Claude API key
# Get it at: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# Required: Pexels API key (free, 200 req/hour)
# Get it at: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# Optional overrides
BLOG_BASE_URL=https://bloghosting-b5700.web.app
GA_MEASUREMENT_ID=G-L3Z7HC2RGD

# For local testing — skip API calls and use sample data
# DRY_RUN=1

# Force a specific category (leave empty or "auto" for automatic)
# CATEGORY=politics
# CATEGORY=economy

# Override the topic for this run
# CUSTOM_TOPIC=Federal Reserve interest rate decision analysis
